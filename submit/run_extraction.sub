universe = vanilla
log = log_$(Cluster).log
output = output_$(Cluster)_$(Process).out
error = error_$(Cluster)_$(Process).err

executable = run_extraction.sh
arguments = $(config)

should_transfer_files = YES
when_to_transfer_output = ON_EXIT

request_gpus = 1
request_cpus = 1
request_memory = 1GB
request_disk = 5GB

+WantGPULab = true
+GPUJobLength = "short"
+is_resumable = true
require_gpus = (Capability > 7.5)
Requirements = (Target.CUDADriverVersion >= 10.2)

queue config from cmd.txt